# ---------- Supabase ----------
# Project URL (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://rwvelroicoxjimldlwrn.supabase.co

# Publishable/anon key (Settings > API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret/service key (Settings > API Keys)
# NEVER expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Database ----------
# Use the Transaction pooler URL for app/runtime connections
# (Connect > ORMs or Connect > Drivers)
DATABASE_URL=postgresql://postgres.rwvelroicoxjimldlwrn:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional direct connection (migrations/CLI)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.rwvelroicoxjimldlwrn.supabase.co:5432/postgres

# ---------- Existing optional var ----------
# Only set if you need custom Chromium for Playwright PDF rendering
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# Public site URL used for SEO metadata, sitemap, and social previews
# Example: https://nexo.example.com
NEXT_PUBLIC_SITE_URL=

# ---------- Waitlist e-mail confirmation (optional but recommended) ----------
# Provider: Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender (must match your verified domain in provider)
WAITLIST_EMAIL_FROM="NEXO <notifications@speck-solutions.com.br>"

# Reply-to for support responses
WAITLIST_EMAIL_REPLY_TO=support@speck-solutions.com.br
